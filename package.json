{
	"name": "heterarchy.fyi",
	"private": true,
	"license": "Unlicense",
	"version": "0.3.0",
	"type": "module",
	"scripts": {
		"build-info": "bun scripts/write-build-info.js",
		"fetch-data": "bun scripts/fetch-data.js",
		"check-translations": "bun scripts/check-translations.js",
		"dev": "vite dev",
		"build": "bun run build-info && vite build",
		"preview": "vite preview",
		"prepare": "(svelte-kit sync || echo '') && bun run fetch-data",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy url baseLocale",
		"check": "bun run paraglide && bun run build-info && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun run paraglide && bun run build-info && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.9.1",
		"isomorphic-git": "^1.38.3",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@inlang/paraglide-js": "^2.18.1",
		"@inlang/paraglide-sveltekit": "^1.0.0-beta.7",
		"@pierre/diffs": "^1.2.2",
		"fuse.js": "^7.3.0",
		"katex": "^0.17.0",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.4",
		"shiki": "^4.1.0"
	}
}
